# ============================================================================
# AgentPass — Environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# Anything marked OPTIONAL can be left unset; the app degrades gracefully.
# ============================================================================

# ─── Payments (Stripe) ──────────────────────────────────────────────────────
# Required to accept money. Until STRIPE_SECRET_KEY is set, the /pricing page
# shows a friendly "launching shortly" message instead of crashing.
# Get the secret key:  Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Recurring Price IDs for the Pro plan. Create a Product "AgentPass Pro" in
# Stripe with two prices ($29/mo and $276/yr) and paste their IDs here.
# Find them under: Stripe Dashboard → Product catalog → your price → "price_..."
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret — lets a successful payment auto-activate the customer's Pro
# plan (app/api/stripe-webhook). Stripe Dashboard → Developers → Webhooks → your
# endpoint → "Signing secret". Point the endpoint at https://YOURDOMAIN/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cryptographic signing ──────────────────────────────────────────────────
# REQUIRED IN PRODUCTION. Signs receipts and the tamper-proof ledger (lib/crypto.ts).
# If unset it falls back to an insecure dev secret — do NOT ship without this.
# Generate one:  openssl rand -hex 32
HMAC_SECRET=replace-with-a-long-random-string

# ─── Database (durable persistence) ─────────────────────────────────────────
# OPTIONAL but strongly recommended. Without it the store is in-memory and wipes
# on every restart/redeploy. Set it and customers, keys, billing & ledgers persist.
# Get a free Postgres URL from Neon (https://neon.tech), Supabase, or Vercel Postgres.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# OPTIONAL. How often (ms) the store snapshots to Postgres. Default 5000.
# SNAPSHOT_INTERVAL_MS=5000

# ─── Public app URL ─────────────────────────────────────────────────────────
# OPTIONAL. Used to build Stripe success/cancel redirect URLs. Auto-detected from
# the request if unset, but set it explicitly in production to be safe.
# Note: NEXT_PUBLIC_ vars are exposed to the browser — only put non-secret values here.
NEXT_PUBLIC_BASE_URL=https://your-domain.com
